# Government data APIs (single key covers Congress.gov, FEC, and GovInfo)
# Sign up free at https://api.data.gov/signup/
DATA_GOV_API_KEY=your-api-data-gov-key

# Google Gemini API key (free tier)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Optional overrides
PIPELINE_GEMINI_MODEL=gemini-2.0-flash
PIPELINE_CACHE_TTL_HOURS=72
PIPELINE_LOG_LEVEL=info
