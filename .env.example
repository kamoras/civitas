# ─── Required ──────────────────────────────────────────────────
# Government data API key (covers Congress.gov, FEC, GovInfo, and Regulations.gov).
# Sign up free at https://api.data.gov/signup/
DATA_GOV_API_KEY=your-api-data-gov-key

# ─── LLM Backend ─────────────────────────────────────────────
# "llama-server" = native llama.cpp server (fastest on ARM/RPi)
# "ollama"       = Ollama Docker service (simpler setup, slower on ARM)
LLM_BACKEND=llama-server

# Native llama-server URL (used when LLM_BACKEND=llama-server).
# Runs as a systemd service on the host; Docker reaches it via host.docker.internal.
LLAMA_SERVER_URL=http://host.docker.internal:8070

# Ollama fallback URL (used when LLM_BACKEND=ollama).
OLLAMA_BASE_URL=http://mp-ollama:11434

# Model name (used for cache key differentiation and Ollama model selection).
OLLAMA_MODEL=qwen2.5:1.5b

# ─── Pipeline ─────────────────────────────────────────────────
# How long to cache API responses before re-fetching (hours).
PIPELINE_CACHE_TTL_HOURS=72

# Logging: debug | info | warning | error
PIPELINE_LOG_LEVEL=info

# Cron expression for automatic pipeline runs (default: 3 AM daily).
PIPELINE_CRON_SCHEDULE=0 3 * * *

# Bearer token for the POST /api/pipeline/run endpoint.
# Generate something random: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PIPELINE_TRIGGER_TOKEN=change-me-to-a-random-token

# Token for the /admin management panel.
# If not set, falls back to PIPELINE_TRIGGER_TOKEN.
ADMIN_TOKEN=change-me-to-a-random-token

# ─── Database ─────────────────────────────────────────────────
# SQLite path inside the container. The /data volume is persisted
# by docker compose so data survives container restarts.
DATABASE_URL=sqlite:////data/modern-punk.db
